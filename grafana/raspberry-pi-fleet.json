{
  "annotations": {
    "list": []
  },
  "description": "Flottenübersicht für alle mit pi-init eingerichteten Raspberry Pis.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "Offline" }, "1": { "color": "green", "text": "Online" } }, "type": "value" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "name" },
      "targets": [
        { "editorMode": "code", "expr": "up{job=\"raspberry-pi\",host=~\"$host\"}", "instant": true, "legendFormat": "{{host}}", "range": false, "refId": "A" }
      ],
      "title": "Erreichbarkeit",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "editorMode": "code", "expr": "100 * (1 - avg by (host) (rate(node_cpu_seconds_total{job=\"raspberry-pi\",host=~\"$host\",mode=\"idle\"}[$__rate_interval])))", "legendFormat": "{{host}}", "range": true, "refId": "A" }
      ],
      "title": "CPU-Auslastung",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "editorMode": "code", "expr": "100 * (1 - node_memory_MemAvailable_bytes{job=\"raspberry-pi\",host=~\"$host\"} / node_memory_MemTotal_bytes{job=\"raspberry-pi\",host=~\"$host\"})", "legendFormat": "{{host}}", "range": true, "refId": "A" }
      ],
      "title": "RAM-Auslastung",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 } ] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "editorMode": "code", "expr": "100 * (1 - node_filesystem_avail_bytes{job=\"raspberry-pi\",host=~\"$host\",mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{job=\"raspberry-pi\",host=~\"$host\",mountpoint=\"/\",fstype!~\"tmpfs|overlay\"})", "legendFormat": "{{host}}", "range": true, "refId": "A" }
      ],
      "title": "Root-Dateisystem",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null }, { "color": "green", "value": 0 }, { "color": "yellow", "value": 65 }, { "color": "red", "value": 75 } ] },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "editorMode": "code", "expr": "pi_cpu_temperature_celsius{job=\"raspberry-pi\",host=~\"$host\"}", "legendFormat": "{{host}}", "range": true, "refId": "A" }
      ],
      "title": "CPU-Temperatur",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "green", "text": "Nein" }, "1": { "color": "red", "text": "Ja" } }, "type": "value" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "name" },
      "targets": [
        { "editorMode": "code", "expr": "pi_undervoltage_since_boot{job=\"raspberry-pi\",host=~\"$host\"}", "instant": true, "legendFormat": "{{host}}", "range": false, "refId": "A" }
      ],
      "title": "Unterspannung seit Boot",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "Nicht synchron" }, "1": { "color": "green", "text": "Synchron" } }, "type": "value" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "id": 7,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "name" },
      "targets": [
        { "editorMode": "code", "expr": "pi_ntp_synchronized{job=\"raspberry-pi\",host=~\"$host\"}", "instant": true, "legendFormat": "{{host}}", "range": false, "refId": "A" }
      ],
      "title": "Zeitsynchronisation",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "text", "text": "Nicht installiert" }, "1": { "color": "green", "text": "Metriken verfügbar" } }, "type": "value" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "id": 8,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "name" },
      "targets": [
        { "editorMode": "code", "expr": "pi_zpl_agent_scrape_success{job=\"raspberry-pi\",host=~\"$host\"}", "instant": true, "legendFormat": "{{host}}", "range": false, "refId": "A" }
      ],
      "title": "ZebraTamer-Metriken",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 9,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "node_load1{job=\"raspberry-pi\",host=~\"$host\"}", "legendFormat": "{{host}} load1", "range": true, "refId": "A" }
      ],
      "title": "Load Average (1 Minute)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["raspberry-pi", "pi-init", "fleet"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(up{job=\"raspberry-pi\"}, host)",
        "hide": 0,
        "includeAll": true,
        "label": "Pi",
        "multi": true,
        "name": "host",
        "options": [],
        "query": { "query": "label_values(up{job=\"raspberry-pi\"}, host)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Raspberry Pi Fleet",
  "uid": "raspberry-pi-fleet",
  "version": 1,
  "weekStart": "monday"
}
